{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PublicDownloadPublicFolder",
      "Effect": "Allow",
      "Principal": {
        "AWS": "*"
      },
      "Action": [
        "s3:GetObject"
      ],
      "Resource": [
        "arn:aws:s3:::contentboxes/public/*"
      ]
    },
    {
      "Sid": "PublicUploadTmpFolder",
      "Effect": "Allow",
      "Principal": {
        "AWS": "*"
      },
      "Action": [
        "s3:PutObject"
      ],
      "Resource": [
        "arn:aws:s3:::contentboxes/tmp/*"
      ]
    }
  ]
}